---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Projects" description="Engineering projects by Wyatt Shore">
  <div class="container" style="padding-top: 4rem; padding-bottom: 6rem;">
    <header class="page-header">
      <h1>Projects</h1>
      <p>Things I've designed, built, and learned from. Each one is a mix of mechanical design, electronics, and software — with the inevitable detour into unexpected problems.</p>
    </header>

    <div class="posts-list">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-row">
          {post.data.featureImage && (
            <div class="post-row-thumb">
              <img src={post.data.featureImage} alt={post.data.title} loading="lazy" />
            </div>
          )}
          <div class="post-row-body">
            <div class="post-row-meta">
              {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
              <time>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</time>
            </div>
            <h2>{post.data.title}</h2>
            {post.data.description && <p>{post.data.description}</p>}
          </div>
          <div class="post-row-arrow">→</div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-header h1 { margin-bottom: 0.75rem; }

  .page-header p {
    color: var(--color-text-muted);
    max-width: 600px;
    font-size: 1.05rem;
    margin: 0;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .post-row {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    gap: 1.5rem;
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    color: var(--color-text);
    transition: border-color 0.2s, transform 0.15s;
  }

  .post-row:hover {
    border-color: var(--color-accent);
    transform: translateX(3px);
    opacity: 1;
  }

  .post-row-thumb {
    width: 140px;
    height: 90px;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .post-row-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-row-body h2 {
    font-size: 1.1rem;
    margin: 0.3rem 0 0.4rem;
  }

  .post-row-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.25rem;
  }

  .post-row-meta time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .post-row-body p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-row-arrow {
    color: var(--color-text-muted);
    font-size: 1.2rem;
    transition: color 0.2s;
  }

  .post-row:hover .post-row-arrow {
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .post-row {
      grid-template-columns: 1fr auto;
    }
    .post-row-thumb { display: none; }
  }
</style>
