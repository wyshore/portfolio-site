---
// ImageRow: renders 2-3 images side-by-side from inside a Markdown post.
// Used either via the directive syntax (:::row ... :::) or as a regular component.
// It accepts children (images) directly. Caption is optional.
interface Props {
  caption?: string;
  cols?: number;
}
const { caption, cols } = Astro.props;
---
<figure class={`img-row${cols ? ` cols-${cols}` : ''}`}>
  <div class="img-row-grid">
    <slot />
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .img-row {
    margin: 2rem 0;
  }
  .img-row-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem;
    align-items: stretch;
  }
  .img-row.cols-2 .img-row-grid { grid-template-columns: repeat(2, 1fr); }
  .img-row.cols-3 .img-row-grid { grid-template-columns: repeat(3, 1fr); }
  .img-row.cols-4 .img-row-grid { grid-template-columns: repeat(4, 1fr); }

  .img-row-grid :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius);
    margin: 0 !important;
    aspect-ratio: 4 / 3;
  }
  .img-row-grid :global(p) {
    margin: 0 !important;
  }
  figcaption {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-style: italic;
    margin-top: 0.6rem;
  }

  @media (max-width: 600px) {
    .img-row.cols-3 .img-row-grid,
    .img-row.cols-4 .img-row-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
